<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_rounded_bg">

    <!-- ── Dialog Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/circle_light_green"
            android:layout_marginEnd="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_group"
                app:tint="#1B4332" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Staff"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update staff member details"
                android:textSize="12sp"
                android:textColor="#888888" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="18dp" />

    <!-- First Name + Last Name row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <!-- First Name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Name"
                android:textSize="12sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEditStaffFname"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Jane"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BBBBBB"
                android:background="@drawable/input_rounded_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textPersonName"
                android:autofillHints="givenName" />

        </LinearLayout>

        <!-- Last Name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Name"
                android:textSize="12sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEditStaffLname"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Doe"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BBBBBB"
                android:background="@drawable/input_rounded_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textPersonName"
                android:autofillHints="familyName" />

        </LinearLayout>

    </LinearLayout>

    <!-- Username Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Username"
        android:textSize="12sp"
        android:textColor="#555555"
        android:layout_marginBottom="6dp" />

    <!-- Username with @ prefix -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="14dp">

        <EditText
            android:id="@+id/etEditStaffUsername"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="jane.doe.staff"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:textColorHint="#BBBBBB"
            android:background="@drawable/input_rounded_bg"
            android:paddingStart="40dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:autofillHints="username" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="14dp"
            android:text="@"
            android:textSize="15sp"
            android:textColor="#888888"
            android:textStyle="bold" />

    </FrameLayout>

    <!-- Password Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Password"
        android:textSize="12sp"
        android:textColor="#555555"
        android:layout_marginBottom="6dp" />

    <!-- Password with toggle -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutEditPassword"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="22dp"
        app:passwordToggleEnabled="true"
        app:boxCornerRadiusTopStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusBottomEnd="10dp"
        app:boxStrokeColor="#E0E0E0"
        app:boxBackgroundColor="#F2F2F2"
        app:startIconDrawable="@drawable/ic_lock"
        app:startIconTint="#888888">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditStaffPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint=""
            android:textSize="14sp"
            android:inputType="textPassword"
            android:autofillHints="password" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelStaffEdit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textSize="14sp"
            android:textColor="#555555"
            android:background="@drawable/btn_outline_grey_rounded"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSaveStaffEdit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Save Changes"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_dark_green_rounded"
            android:stateListAnimator="@null"
            app:backgroundTint="@null"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>